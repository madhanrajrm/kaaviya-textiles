DATABASE_URL="file:./dev.db"
AUTH_SECRET="change-this-to-a-long-random-string-in-production"

# Report email (optional default; can also save in Settings UI)
REPORT_EMAIL_TO="your-email@example.com"

# SMTP for sending reports (Gmail: enable 2FA, create App Password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="your@gmail.com"
